# TORCH — Environment Variables
# Copy this to .env and fill in your values

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Gmail (App Password auth)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Voice
WAKE_WORD=hey torch
WAKE_WORD_SENSITIVITY=0.5
WHISPER_MODEL_SIZE=base

# Screen Watch
SCREEN_WATCH_ENABLED=false
SCREEN_WATCH_INTERVAL=30

# Server
TORCH_HOST=0.0.0.0
TORCH_PORT=8000
TORCH_DATA_DIR=./data
TORCH_DB_PATH=./data/torch.db
TORCH_RELOAD=true

# Agent retry handling
TORCH_AGENT_RETRY_ENABLED=true
TORCH_AGENT_RETRY_ATTEMPTS=2
TORCH_AGENT_RETRY_DELAY_SECONDS=0.5
TORCH_AGENT_RETRY_TOOLS=find_file,list_directory,read_pdf,read_word,read_excel,read_inbox,open_browser,search_web,download_file,screenshot,analyse_screen

# Electron backend health monitoring
TORCH_BACKEND_HEALTH_INTERVAL_MS=10000
TORCH_BACKEND_HEALTH_TIMEOUT_MS=3000
TORCH_BACKEND_MAX_FAILED_CHECKS=3
TORCH_BACKEND_RESTART_DELAY_MS=1000
