# TORCH — Environment Variables
# Copy this to .env and fill in your values

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Gmail (App Password auth)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Voice
WAKE_WORD=hey torch
WAKE_WORD_SENSITIVITY=0.5
WHISPER_MODEL_SIZE=base

# Screen Watch
SCREEN_WATCH_ENABLED=false
SCREEN_WATCH_INTERVAL=30

# Server
TORCH_HOST=0.0.0.0
TORCH_PORT=8000
TORCH_DATA_DIR=./data
TORCH_DB_PATH=./data/torch.db
